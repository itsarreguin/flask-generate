[% if orm == "sqlalchemy" %]
    [%- include "scaffolding/ext_sqla.py-tpl" -%]
[% else %]
    [%- include "scaffolding/ext_peewee.py-tpl" -%]
[% endif %]


def register_extensions(app: Flask) -> None:
    generate.init_app(app)
    csrf.init_app(app)
    [%- if orm == 'sqlalchemy' %]
    db.init_app(app)
    migrate.init_app(app, db)
    [%- endif -%]