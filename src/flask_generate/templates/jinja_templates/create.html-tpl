{% extends "base.html.jinja" %}

{% block content %}
  <header>
    <h1>[[ snake_to_title(blueprint_name) ]]</h1>
    <a href="{{ url_for('[[blueprint_name]].index') }}">Back</a>
  </header>
  <div>
    {% with endpoint = url_for('[[ blueprint_name ]].create') %}
      {% include "[[ blueprint_name ]]/_form.html.jinja" %}
    {% endwith %}
  </div>
{% endblock content %}