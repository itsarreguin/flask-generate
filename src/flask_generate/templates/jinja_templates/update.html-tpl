{% extends "base.html.jinja" %}

{% block content %}
  <header>
    <h1>Update [[ snake_to_title(blueprint_name) ]]: {{ obj.id }}</h1>
    <a href="{{ url_for('[[blueprint_name]].detail', id=obj.id) }}">Back</a>
  </header>

  <div>
    {% with endpoint = url_for('[[ blueprint_name ]].update', id=obj.id) %}
      {% include "[[ blueprint_name ]]/_form.html.jinja" %}
    {% endwith %}
  </div>
{% endblock content %}