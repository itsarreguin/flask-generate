from flask import Blueprint, request, render_template
from flask.wrappers import Response


path = Blueprint('[[ blueprint_name ]]', __name__, url_prefix='/[[ blueprint_name ]]')


@path.route('/')
def index() -> Response:
    pass


@path.route('/create/')
def create() -> Response:
    pass


@path.route('/<int:id>/update/')
def update(id: int) -> Response:
    pass


@path.route('/<int:id>/delete/')
def delete(id: int) -> Response:
    pass